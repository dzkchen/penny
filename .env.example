# Copy this file to `.env` (which is gitignored) and fill in real values there.
# NEVER put real secrets in this file — it is committed to git.

# Anthropic API key (only needed once Penny uses live Claude agents).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional model overrides (not required for the core demo).
PENNY_FAST_MODEL=
PENNY_DEEP_MODEL=

# Model mode: auto (Haiku chat + Sonnet work) | haiku | sonnet
PENNY_MODEL_MODE=auto

# Set to 1 to default ownership confirmation on (skip typing /own or --i-own-this).
# Only enable if you exclusively test targets you own.
PENNY_I_OWN_THIS=

# Voyage AI embedding key — real semantic vectors for Mongo vector search.
# Leave blank to fall back to deterministic hash embeddings.
VOYAGE_API_KEY=

# Optional MongoDB Atlas connection (P1 — knowledge base + trends).
# Leave blank to run the core demo without Mongo.
MONGODB_URI=
PENNY_MONGODB_DB=penny

# --- Cloud tier (Vultr) -----------------------------------------------------
# Vultr API key — enables the heavy cloud tier and the heretic/gemma-3 sandbox.
VULTR_API_KEY=

# --- sandbox-test (heretic/gemma-3 active-breach GPU box) --------------------
# GPU plan/region for the sandbox. Defaults: A16 1-GPU (16 GB VRAM) @ ~$0.471/hr.
# Use vcg-a16-12c-128g-32vram (~$0.942/hr) if you bake gemma-3-12b.
VULTR_GPU_PLAN=
VULTR_GPU_REGION=
# Pre-decensored model to SERVE on the box (transformers/safetensors repo, NOT *-GGUF).
# Defaults to the official heretic-org Qwen3-4B-Thinking build — a reasoning model that's
# good at multi-step attack planning, and more robust than running heretic unattended
# (heretic is interactive + needs ~30-45 min GPU). Point this at your own repo if you
# abliterate one yourself.
PENNY_HERETIC_MODEL=heretic-org/Qwen3-4B-Thinking-2507-heretic
# Hugging Face token — needed only if the chosen model is gated (the default is not).
HF_TOKEN=
# vLLM pip spec for the bake. Default pins a CUDA 12.4 (torch 2.6/cu124) build to match
# Vultr's GPU-image driver. Only change if you upgrade the box driver to CUDA 12.8+.
PENNY_VLLM_SPEC=vllm==0.8.5.post1
# Filled in automatically by `penny sandbox-bake` (also stored in .penny/sandbox.json).
PENNY_SANDBOX_SNAPSHOT_ID=
