# Copy this file to `.env` (which is gitignored) and fill in real values there.
# NEVER put real secrets in this file — it is committed to git.

# Anthropic API key (only needed once Penny uses live Claude agents).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional model overrides (not required for the core demo).
PENNY_FAST_MODEL=
PENNY_DEEP_MODEL=

# Optional MongoDB Atlas connection (P1 — knowledge base + trends).
# Leave blank to run the core demo without Mongo.
MONGODB_URI=
PENNY_MONGODB_DB=penny
